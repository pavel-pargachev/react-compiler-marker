{
  "name": "react-compiler-marker",
  "displayName": "React Compiler Marker",
  "description": "Highlights components optimized by the React Compiler, providing visual cues to make the optimization process more transparent during development.",
  "version": "2.2.65",
  "author": "Pavel Pargachev <pargachev@gmail.com>",
  "contributors": [
    "Blazej Kustra <kustrablazej@gmail.com>"
  ],
  "publisher": "pavel-pargachev",
  "license": "MIT",
  "keywords": [
    "react",
    "react-compiler",
    "react-components",
    "vscode-extension",
    "optimization",
    "lsp",
    "language-server"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/pavel-pargachev/react-compiler-marker"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Visualization"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact"
  ],
  "main": "./dist/extension.js",
  "icon": "logo.jpeg",
  "contributes": {
    "languages": [
      {
        "id": "reactCompilerCompiledPreview",
        "aliases": [
          "React Compiler Compiled Preview"
        ],
        "extensions": [
          ".react-compiler-preview.ts",
          ".react-compiler-preview.tsx",
          ".react-compiler-preview.js",
          ".react-compiler-preview.jsx"
        ]
      }
    ],
    "grammars": [
      {
        "language": "reactCompilerCompiledPreview",
        "scopeName": "source.react-compiler-preview",
        "path": "./syntaxes/react-compiler-preview.json"
      }
    ],
    "configurationDefaults": {
      "problems.exclude": {
        "react-compiler-preview:/**": true,
        "react-compiler-format-scratch:/**": true
      },
      "[reactCompilerCompiledPreview]": {
        "editor.semanticHighlighting.enabled": false
      }
    },
    "commands": [
      {
        "command": "react-compiler-marker.activate",
        "title": "Activate Extension",
        "category": "React Compiler Marker"
      },
      {
        "command": "react-compiler-marker.deactivate",
        "title": "Deactivate Extension",
        "category": "React Compiler Marker"
      },
      {
        "command": "react-compiler-marker.checkOnce",
        "title": "Check in the current file",
        "category": "React Compiler Marker"
      },
      {
        "command": "react-compiler-marker.previewCompiled",
        "title": "Preview Compiled Output",
        "category": "React Compiler Marker"
      }
    ],
    "configuration": {
      "title": "React Compiler Marker",
      "properties": {
        "reactCompilerMarker.babelPluginPath": {
          "type": "string",
          "default": "node_modules/babel-plugin-react-compiler",
          "description": "Path to the babel-plugin-react-compiler in your project."
        },
        "reactCompilerMarker.configFile": {
          "type": "string",
          "default": ".config/react-compiler.ts",
          "markdownDescription": "Workspace-relative path to a module that exports `reactCompilerPaths` (string array). This list defines parts of the code that use compilationMode=infer, the rest of the code uses annotation mode (`'use memo'` opt-in)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run typecheck && npm run lint && node ../../esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node ../../esbuild.js --watch",
    "watch:tsc": "tsc -b --watch",
    "package": "npm run typecheck && npm run lint && node ../../esbuild.js --production",
    "compile-tests": "tsc -b",
    "watch-tests": "tsc -b -w",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "typecheck": "tsc -b",
    "lint": "eslint \"src/**/*.ts\" \"../../packages/server/src/**/*.ts\"",
    "test": "vscode-test"
  },
  "dependencies": {
    "@react-compiler-marker/shared": "*",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.9",
    "@types/node": "20.x",
    "@types/vscode": "^1.95.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.24.0",
    "npm-run-all2": "^8.0.4"
  }
}
